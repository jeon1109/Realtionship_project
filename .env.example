# Supabase settings for a future cloud sync/storage mode.
# Keep real values in `.env.local`; never commit secrets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Use `local` for browser-only localStorage.
# Use `supabase` after creating the Supabase tables in docs/supabase-schema.sql.
NEXT_PUBLIC_JOURNAL_STORAGE=local
